{
  "manifest_version": 3,
  "name": "PokerNow GPT Bot",
  "version": "1.0.0",
  "description": "AI-powered poker assistant for PokerNow.com",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:3000/*"],
  "content_scripts": [
    {
      "matches": [
        "https://www.pokernow.com/games/*",
        "https://pokernow.com/games/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
